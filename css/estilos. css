.entrada{
    max-width:900px;
    margin:40px auto;
    padding:20px;
    font-family:Arial, Helvetica, sans-serif;
}

.galeria{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
    margin-top:30px;
}

.foto{
    background:#fff;
    border:1px solid #ddd;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 4px 10px rgba(0,0,0,.1);
}

.foto img{
    width:100%;
    display:block;
}

.foto figcaption{
    padding:15px;
}

.foto h3{
    margin:0 0 10px;
}

.foto p{
    margin:0;
    color:#555;
    line-height:1.5;
}
